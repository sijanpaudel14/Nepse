# NEPSE AI Trading Bot - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# ============ DATABASE ============
DATABASE_URL=sqlite:///./nepse_data.db

# ============ OPENAI ============
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============ TELEGRAM ============
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-personal-chat-id-here

# ============ EMAIL (Optional) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com

# ============ TRADING PARAMETERS ============
# Risk per trade as decimal (0.02 = 2%)
RISK_PER_TRADE=0.02
# Maximum number of open positions
MAX_POSITIONS=5
# Minimum stock price filter (Rs.)
MIN_PRICE=200
# Target profit percentage (0.10 = 10%)
TARGET_PROFIT=0.10
# Stop loss percentage (0.05 = 5%)
STOP_LOSS=0.05

# ============ API SETTINGS ============
# For future SaaS: JWT secret key
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=nepse_bot.log

# ============ SHAREHUB AUTH (Optional, for protected endpoints) ============
# Bearer token used by broker-analysis and broker-accumulation endpoints
SHAREHUB_AUTH_TOKEN=

# Option A: cookie header format copied from browser/curl
# Example: route=...; SRVGROUP=common; _clck=...; _ga=...; _gcl_au=...; _ga_13E8FKZMQ2=...; _clsk=...
SHAREHUB_AUTH_COOKIES=

# Option B: JSON object string for cookies (use this instead of SHAREHUB_AUTH_COOKIES if preferred)
# SHAREHUB_AUTH_COOKIES_JSON={"route":"...","SRVGROUP":"common"}
SHAREHUB_AUTH_COOKIES_JSON=

# ============ SCHEDULER ============
# Run analysis at this time (24h format, Nepal Time)
ANALYSIS_TIME=10:30
# Enable/disable scheduler
SCHEDULER_ENABLED=true
