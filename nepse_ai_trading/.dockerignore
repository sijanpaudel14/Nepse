# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class

# Ignore virtual environments
venv/
.venv/
env/

# Ignore IDE files
.idea/
.vscode/
*.swp

# Ignore test files
tests/
*.test.py

# Ignore development files
*.md
!README.md
.git/
.gitignore

# Ignore environment files
.env
.env.local

# Ignore logs
*.log
logs/

# Ignore build artifacts
dist/
build/
*.egg-info/

# Ignore data files (mount as volume instead)
# BUT: Keep the data/ module code, only ignore data files
data/*.db
data/*.sqlite
data/*.csv
data/*.json
*.db
*.sqlite

# Ignore notebooks
*.ipynb
