      "primary_foreground": "<HSL>",
      "secondary": "<HSL>",
      "secondary_foreground": "<HSL>",
      "muted": "<HSL>",
      "muted_foreground": "<HSL>",
      "accent": "<HSL>",
      "accent_foreground": "<HSL>",
      "destructive": "<HSL>",
      "destructive_foreground": "<HSL>",
      "border": "<HSL>",
      "input": "<HSL>",
      "ring": "<HSL>"
