      "config": "tailwind.config.ts (extend theme)"
    },
    "required_dependencies": [
      "lucide-react",
      "clsx",
      "tailwind-merge",
      "framer-motion",
      "sonner"
    ]
  },
  "typography": {
    "primary_font": "<Name of font for Headings (e.g. Manrope, Syne, Clash Display)>",
    "secondary_font": "<Name of font for Body (e.g. Inter, DM Sans)>",
    "mono_font": "<Name of monospace font (e.g. JetBrains Mono, Space Mono)>",
    "google_fonts_url": "<URL to import these fonts>",
    "scaling": {
      "h1": "text-5xl md:text-7xl lg:text-8xl tracking-tighter",
      "h2": "text-4xl md:text-5xl tracking-tight",
      "h3": "text-2xl md:text-3xl font-semibold",
      "body": "text-base md:text-lg leading-relaxed",
      "caption": "text-sm text-muted-foreground uppercase tracking-widest"
    },
    "rules": {
      "headings": "<Tailwind classes for headings (e.g. font-bold uppercase)>",
