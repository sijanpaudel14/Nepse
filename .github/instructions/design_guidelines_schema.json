      "surface_card": "bg-card border border-border/50 hover:border-primary/20 transition-colors"
    }
  },
  "layout": {
    "spacing_scale": "<Values: Tight | Comfortable | Spacious (e.g. p-6 md:p-12)>",
    "container_padding": "<Tailwind padding classes>",
    "border_radius": "<rounded-none | rounded-sm | rounded-2xl | rounded-full>",
    "grid_system": "<One of: Asymmetrical | Bento | Masonry | Modular>",
    "rules": [
      "No 3-column centralized feature grids.",
      "Use negative space (empty areas) to guide the eye.",
      "Align text left for power; center only for poetic pause."
    ]
  },
  "components": {
    "navigation": {
      "style": "<Floating | Sidebar | Minimal Header>",
      "classes": "fixed top-4 left-1/2 -translate-x-1/2 rounded-full border border-white/10 bg-black/50 backdrop-blur-md px-6 py-3"
    },
    "buttons": {
      "style": "<Pill | Sharp | Brutalist>",
      "default": "<Tailwind classes>",
      "primary": "<Tailwind classes>",
      "ghost": "hover:bg-accent/50 text-accent-foreground"
    },
    "cards": {
      "style": "<Glass | Solid | Outline>",
      "classes": "<Tailwind classes>"
    },
    "inputs": {
      "style": "<Underlined | Boxed | Floating Label>",
      "classes": "<Tailwind classes>"
    },
    "hero_section": {
      "layout": "<Split | Immersive | Typographic>",
      "rules": "No generic Rocket/Startup illustrations. Use abstract shapes or huge typography."
    },
    "data_display": {
      "style": "<Minimal | Cyber | Medical>",
      "chart_colors": [
        "hsl(var(--primary))",
        "hsl(var(--secondary))",
        "hsl(var(--accent))"
      ]
    }
  },
  "micro_interactions": {
    "hover_physics": "transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] hover:scale-[1.02]",
    "click_physics": "active:scale-[0.98]",
    "scroll_reveal_stagger": "0.1s",
    "hover": "scale-[1.01] brightness-110",
    "active": "scale-[0.98]",
    "animation_library": "framer-motion",
    "animation_presets": {
      "fade_up": "{ initial: { opacity: 0, y: 20 }, animate: { opacity: 1, y: 0 } }",
      "stagger_children": "{ visible: { transition: { staggerChildren: 0.1 } } }"
    }
  },
  "visual_enhancers": {
    "textures": "<Noise | Grain | Mesh Gradient | Dot Pattern>",
    "gradients": "Use vivid, asymmetric gradients. No linear top-to-bottom defaults.",
    "shadows": "<Glow | Hard Shadow | Soft Diffusion>",
    "motion": "Use framer-motion. Entry: opacity-0 y-10 -> opacity-100 y-0."
  },
  "icons": {
    "library": "lucide-react",
    "style": "stroke-1.5",
    "usage": "Use large icons (w-6 h-6). Animate stroke on hover."
  },
  "anti_ai_constraints": [
    "FORBIDDEN: Standard Shadcn Slate-900/Violet-500 palette.",
    "FORBIDDEN: 'Start your journey' or 'Unlock the power' copy.",
    "FORBIDDEN: Placeholder images (Use generated or abstract).",
    "FORBIDDEN: Symmetrical 3-column pricing tables (Use staggered or highlighted)."
  ],
  "instructions_to_agent": "Fill this schema based on the User's request. If they want 'Cyberpunk', choose neon colors and brutalist buttons. If 'Zen', choose earth tones and soft radii. THEN, override index.css immediately."
}
